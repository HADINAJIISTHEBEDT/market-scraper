{
  "name": "dessert-cafe-manager",
  "version": "1.0.0",
  "description": "Dessert Cafe Manager - Timer and Market Price Tracker",
  "main": "main.js",
  "bin": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "pkg . --targets node18-win-x64 --output DessertCafeManager.exe",
    "build-all": "pkg . --targets node18-win-x64,node18-macos-x64,node18-linux-x64"
  },
  "pkg": {
    "scripts": [
      "server.js",
      "scraper.js"
    ],
    "assets": [
      "index.html",
      "frontend.js",
      "css.css",
      "manifest.json",
      "sw.js"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sparticuz/chromium": "^133.0.0",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "puppeteer": "^24.0.0",
    "puppeteer-core": "^24.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "node-windows": "^1.0.0-beta.8",
    "pkg": "^5.8.1"
  }
}
